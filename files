export const FREE_SHIPPING_THRESHOLD = 75;
export const FLAT_SHIPPING_RATE = 8;

export const HOUSE_DISCOUNT_CODE = "HERETIC";
export const HOUSE_DISCOUNT_ALIASES = [HOUSE_DISCOUNT_CODE, "HOUSEOFHERETICS"];
export const HOUSE_DISCOUNT_THRESHOLD = 101;
export const HOUSE_REGULAR_DISCOUNT_RATE = 0.05;
export const HOUSE_HIGH_VALUE_DISCOUNT_RATE = 0.25;

export interface AppliedDiscount {
  code: string;
  label: string;
  rate: number;
  amount: number;
}

export function roundCurrency(amount: number) {
  return Math.round(amount * 100) / 100;
}

export function normalizeDiscountCode(code: string) {
  return code.trim().toUpperCase().replace(/[^A-Z0-9]/g, "");
}

export function getHouseDiscountRate(subtotal: number) {
  return subtotal >= HOUSE_DISCOUNT_THRESHOLD
    ? HOUSE_HIGH_VALUE_DISCOUNT_RATE
    : HOUSE_REGULAR_DISCOUNT_RATE;
}

export function calculateHouseDiscount(subtotal: number) {
  if (subtotal <= 0) return 0;
  return roundCurrency(subtotal * getHouseDiscountRate(subtotal));
}

export function getDiscountForCode(code: string, subtotal: number): AppliedDiscount | null {
  const normalizedCode = normalizeDiscountCode(code);
  if (!normalizedCode || !HOUSE_DISCOUNT_ALIASES.includes(normalizedCode)) return null;

  const rate = getHouseDiscountRate(subtotal);
  return {
    code: HOUSE_DISCOUNT_CODE,
    label:
      rate === HOUSE_HIGH_VALUE_DISCOUNT_RATE
        ? `House discount ${Math.round(rate * 100)}% off $${HOUSE_DISCOUNT_THRESHOLD}+`
        : `House discount ${Math.round(rate * 100)}% off`,
    rate,
    amount: calculateHouseDiscount(subtotal),
  };
}

export function calculateDiscountedSubtotal(subtotal: number, discount = 0) {
  return roundCurrency(Math.max(0, subtotal - discount));
}

export function calculateShipping(subtotal: number) {
  if (subtotal === 0 || subtotal > FREE_SHIPPING_THRESHOLD) return 0;
  return FLAT_SHIPPING_RATE;
}

export function calculateOrderTotal(subtotal: number, discount = 0) {
  const discountedSubtotal = calculateDiscountedSubtotal(subtotal, discount);
  return roundCurrency(discountedSubtotal + calculateShipping(discountedSubtotal));
}
